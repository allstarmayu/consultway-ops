# ─────────────────────────────────────────────────────────────
# Consultway Ops — environment variables
# Copy to `.env.local` for development. Never commit `.env.local`.
# Production/staging secrets live in Cloudflare (see docs/09-deployment.md).
# ─────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Consultway Ops"

# ── Secrets (generate with: openssl rand -base64 32) ─────────
# Used by Payload CMS to sign sessions + encrypt JWTs.
PAYLOAD_SECRET=replace-me-generate-with-openssl

# Used by our own auth layer for session tokens.
JWT_SECRET=replace-me-generate-with-openssl

# Password pepper — added to bcrypt input. Rotate carefully (invalidates all passwords).
PASSWORD_PEPPER=replace-me-generate-with-openssl

# ── Database (Cloudflare D1) ─────────────────────────────────
# In local dev, D1 runs via Miniflare — this path points at the local SQLite file.
# In production, D1 binding is configured in wrangler.jsonc (no URL needed at runtime).
DATABASE_URL=file:./.wrangler/state/v3/d1/miniflare-D1DatabaseObject/consultway_local.sqlite

# D1 binding name (must match wrangler.jsonc)
D1_BINDING=DB

# ── Object storage (Cloudflare R2) ───────────────────────────
# Local dev uses Miniflare's in-memory R2 — values don't need to be real.
R2_BUCKET=consultway-docs-local
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=local
R2_SECRET_ACCESS_KEY=local
# Public base URL for R2 objects (custom domain in prod, local route in dev).
R2_PUBLIC_URL=http://localhost:3000/r2
# Presigned URL expiry for uploads (seconds). Default 15 minutes.
R2_PRESIGN_EXPIRY=900
# Max upload size in bytes. Default 20 MB.
R2_MAX_UPLOAD_BYTES=20971520

# ── Email (Resend) ───────────────────────────────────────────
# Get a test key from https://resend.com/api-keys — dev keys only send to verified addresses.
RESEND_API_KEY=re_test_replace_me
EMAIL_FROM="Consultway <noreply@consultway.local>"
EMAIL_REPLY_TO=support@consultway.local
# If set, all outgoing mail is redirected here instead of the real recipient (dev only).
EMAIL_DEV_REDIRECT=

# ── Observability ────────────────────────────────────────────
LOG_LEVEL=info
# Optional — Sentry DSN for error tracking. Leave blank to disable.
SENTRY_DSN=
# Optional — Cloudflare Analytics token for custom events.
ANALYTICS_TOKEN=

# ── Feature flags ────────────────────────────────────────────
# Toggle Phase 3 modules. Default off until Phase 3 lands.
FEATURE_PROJECTS=false
FEATURE_TRANSACTIONS=false
FEATURE_PDF_REPORTS=false

# ── Rate limiting ────────────────────────────────────────────
# Requests per minute per IP for public endpoints (login, register).
RATE_LIMIT_PUBLIC_RPM=20
# Requests per minute per user for authenticated endpoints.
RATE_LIMIT_AUTH_RPM=120

# ── Cron / scheduled tasks ───────────────────────────────────
# Secret required by /api/cron/* endpoints — Cloudflare triggers pass this as a header.
CRON_SECRET=replace-me-generate-with-openssl

# ── Dev-only ─────────────────────────────────────────────────
# Set to "1" to seed a demo dataset on next `pnpm dev` start.
DEV_AUTO_SEED=0
# Set to "1" to bypass email verification in dev.
DEV_SKIP_EMAIL_VERIFY=0
